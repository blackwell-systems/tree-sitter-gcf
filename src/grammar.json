{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "gcf",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_line"
      }
    },
    "_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "header"
        },
        {
          "type": "SYMBOL",
          "name": "summary_line"
        },
        {
          "type": "SYMBOL",
          "name": "section_header"
        },
        {
          "type": "SYMBOL",
          "name": "edge_line"
        },
        {
          "type": "SYMBOL",
          "name": "ref_line"
        },
        {
          "type": "SYMBOL",
          "name": "symbol_line"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "inline_array"
        },
        {
          "type": "SYMBOL",
          "name": "nested_field"
        },
        {
          "type": "SYMBOL",
          "name": "kv_line"
        },
        {
          "type": "SYMBOL",
          "name": "tabular_row"
        },
        {
          "type": "SYMBOL",
          "name": "text_line"
        },
        {
          "type": "SYMBOL",
          "name": "blank_line"
        }
      ]
    },
    "blank_line": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "header": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "gcf_keyword"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": " "
              },
              {
                "type": "SYMBOL",
                "name": "kv_pair"
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "gcf_keyword": {
      "type": "STRING",
      "value": "GCF"
    },
    "kv_pair": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "key"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "SYMBOL",
          "name": "kv_value"
        }
      ]
    },
    "key": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "kv_value": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "summary_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_summary_marker"
        },
        {
          "type": "SYMBOL",
          "name": "_ws"
        },
        {
          "type": "SYMBOL",
          "name": "_summary_keyword"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": " "
              },
              {
                "type": "SYMBOL",
                "name": "kv_pair"
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_summary_marker": {
      "type": "STRING",
      "value": "##!"
    },
    "_summary_keyword": {
      "type": "ALIAS",
      "content": {
        "type": "STRING",
        "value": "summary"
      },
      "named": true,
      "value": "summary_keyword"
    },
    "section_header": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_section_marker"
        },
        {
          "type": "SYMBOL",
          "name": "_ws"
        },
        {
          "type": "SYMBOL",
          "name": "section_name"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_ws"
                },
                {
                  "type": "SYMBOL",
                  "name": "count_bracket"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "field_decl"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "REPEAT",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_ws"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "kv_pair"
                  }
                ]
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_section_marker": {
      "type": "STRING",
      "value": "##"
    },
    "section_name": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "count_bracket": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "number"
            },
            {
              "type": "SYMBOL",
              "name": "deferred"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "deferred": {
      "type": "STRING",
      "value": "?"
    },
    "field_decl": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "field_name"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "field_name"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "field_name": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "symbol_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "local_id"
        },
        {
          "type": "SYMBOL",
          "name": "_ws"
        },
        {
          "type": "SYMBOL",
          "name": "kind"
        },
        {
          "type": "SYMBOL",
          "name": "_ws"
        },
        {
          "type": "SYMBOL",
          "name": "qualified_name"
        },
        {
          "type": "SYMBOL",
          "name": "_ws"
        },
        {
          "type": "SYMBOL",
          "name": "score"
        },
        {
          "type": "SYMBOL",
          "name": "_ws"
        },
        {
          "type": "SYMBOL",
          "name": "provenance"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "local_id": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "at_sign"
        },
        {
          "type": "SYMBOL",
          "name": "id_number"
        }
      ]
    },
    "at_sign": {
      "type": "STRING",
      "value": "@"
    },
    "id_number": {
      "type": "PATTERN",
      "value": "\\d+"
    },
    "kind": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "fn"
        },
        {
          "type": "STRING",
          "value": "type"
        },
        {
          "type": "STRING",
          "value": "method"
        },
        {
          "type": "STRING",
          "value": "iface"
        },
        {
          "type": "STRING",
          "value": "var"
        },
        {
          "type": "STRING",
          "value": "const"
        },
        {
          "type": "STRING",
          "value": "resource"
        },
        {
          "type": "STRING",
          "value": "table"
        },
        {
          "type": "STRING",
          "value": "class"
        },
        {
          "type": "STRING",
          "value": "selector"
        },
        {
          "type": "STRING",
          "value": "field"
        },
        {
          "type": "STRING",
          "value": "route"
        },
        {
          "type": "STRING",
          "value": "ext"
        },
        {
          "type": "STRING",
          "value": "file"
        },
        {
          "type": "STRING",
          "value": "pkg"
        },
        {
          "type": "STRING",
          "value": "svc"
        }
      ]
    },
    "qualified_name": {
      "type": "PATTERN",
      "value": "[^\\s]+"
    },
    "score": {
      "type": "PATTERN",
      "value": "\\d+\\.\\d+"
    },
    "provenance": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "edge_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "target_id"
        },
        {
          "type": "SYMBOL",
          "name": "arrow"
        },
        {
          "type": "SYMBOL",
          "name": "source_id"
        },
        {
          "type": "SYMBOL",
          "name": "_ws"
        },
        {
          "type": "SYMBOL",
          "name": "edge_type"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_ws"
                },
                {
                  "type": "SYMBOL",
                  "name": "status"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "target_id": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "at_sign"
        },
        {
          "type": "SYMBOL",
          "name": "id_number"
        }
      ]
    },
    "arrow": {
      "type": "STRING",
      "value": "<"
    },
    "source_id": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "at_sign"
        },
        {
          "type": "SYMBOL",
          "name": "id_number"
        }
      ]
    },
    "edge_type": {
      "type": "PATTERN",
      "value": "[a-zA-Z_]+"
    },
    "status": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "added"
        },
        {
          "type": "STRING",
          "value": "removed"
        }
      ]
    },
    "ref_line": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "@\\d+"
          },
          {
            "type": "PATTERN",
            "value": "  # previously transmitted"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "# "
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "inline_array": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[a-zA-Z_][a-zA-Z0-9_]*"
          },
          {
            "type": "PATTERN",
            "value": "\\[\\d+\\]"
          },
          {
            "type": "STRING",
            "value": ": "
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]+"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "nested_field": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "\\s*"
          },
          {
            "type": "STRING",
            "value": "."
          },
          {
            "type": "PATTERN",
            "value": "[a-zA-Z_][a-zA-Z0-9_]*"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "kv_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_indent"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "key"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "SYMBOL",
          "name": "kv_value"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_indent": {
      "type": "PATTERN",
      "value": " +"
    },
    "tabular_row": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[^\\n]*\\|[^\\n]*"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "text_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "text_content"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "text_content": {
      "type": "PATTERN",
      "value": "[a-fh-zA-FH-Z0-9][^\\n=|]*"
    },
    "_ws": {
      "type": "PATTERN",
      "value": " +"
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "number": {
      "type": "PATTERN",
      "value": "\\d+"
    }
  },
  "extras": [],
  "conflicts": [
    [
      "tabular_row"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}