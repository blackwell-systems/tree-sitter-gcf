{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "gcf",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_line"
      }
    },
    "_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "header"
        },
        {
          "type": "SYMBOL",
          "name": "summary_line"
        },
        {
          "type": "SYMBOL",
          "name": "section_header"
        },
        {
          "type": "SYMBOL",
          "name": "edge_line"
        },
        {
          "type": "SYMBOL",
          "name": "ref_line"
        },
        {
          "type": "SYMBOL",
          "name": "symbol_line"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "kv_line"
        },
        {
          "type": "SYMBOL",
          "name": "inline_array"
        },
        {
          "type": "SYMBOL",
          "name": "nested_field"
        },
        {
          "type": "SYMBOL",
          "name": "tabular_row"
        },
        {
          "type": "SYMBOL",
          "name": "blank_line"
        }
      ]
    },
    "blank_line": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "header": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "GCF "
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]+"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "summary_line": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "## _summary"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "section_header": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "## "
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]+"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "edge_line": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "@\\d+<@\\d+"
          },
          {
            "type": "PATTERN",
            "value": " "
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]+"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "ref_line": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "@\\d+"
          },
          {
            "type": "PATTERN",
            "value": "  # previously transmitted"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "symbol_line": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "@\\d+ "
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]+"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "# "
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "kv_line": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[a-zA-Z_][a-zA-Z0-9_]*"
          },
          {
            "type": "STRING",
            "value": "="
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "inline_array": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[a-zA-Z_][a-zA-Z0-9_]*"
          },
          {
            "type": "PATTERN",
            "value": "\\[\\d+\\]"
          },
          {
            "type": "STRING",
            "value": ": "
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]+"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "nested_field": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "\\s*"
          },
          {
            "type": "STRING",
            "value": "."
          },
          {
            "type": "PATTERN",
            "value": "[a-zA-Z_][a-zA-Z0-9_]*"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "tabular_row": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[^\\n]*\\|[^\\n]*"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}