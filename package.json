{
  "name": "tree-sitter-gcf",
  "version": "1.3.2",
  "description": "Tree-sitter grammar for GCF (token-optimized wire format for LLMs)",
  "main": "bindings/node",
  "keywords": ["tree-sitter", "gcf", "parser", "syntax-highlighting"],
  "license": "MIT",
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "test:conformance": "node scripts/parse-conformance.mjs",
    "build:wasm": "tree-sitter build --wasm"
  },
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.26.0"
  },
  "tree-sitter": [
    {
      "scope": "source.gcf",
      "file-types": ["gcf"],
      "highlights": "queries/highlights.scm"
    }
  ]
}
